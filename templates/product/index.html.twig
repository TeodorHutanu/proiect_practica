{% extends 'base.html.twig' %}

{% block title %} Hello ProductController ! {% endblock %}

{% block body %}
<h1> Products </h1>
<table>
    <thread>
        <tr>
        <th>Name</th>
        <th>Description</th>
        <th>Size</th>
        </tr>  
    </thread>
    <tbody>
