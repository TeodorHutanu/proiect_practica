{% extends "base.html.twig" %}

{% block title%} {{parent()}} Where is my Horse {% endblock %}

{% block body %}

<h1> Horseshop: your monopoly-busting options for horses </h1>
<div>
Browse through {{numberofHorses=numberofHorses-400}} Horses!
{%if numberofHorses > 400%}

<p>
Many Horses
</p>

{%endif%}


{%if numberofHorses < 400%}

<p>
Few Horses
</p>

{%endif%}

</div>

<div>
    <h2>My Horse</h2>

    <tabel>
        <tr>
            <th>name</th>
            <td>{{ myhorse.name }}</td>
        </tr>
    </tabel>
</div>
{% endblock %}